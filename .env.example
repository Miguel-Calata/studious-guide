# =============================================================================
# SAM Platform — variables de entorno (Coolify / Docker Compose)
# Copiar a .env para local:  cp .env.example .env
# En Coolify: pegar estas variables en el dashboard del servicio Compose.
# =============================================================================

# --- PostgreSQL (requerido) ---
POSTGRES_USER=sam
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sam_platform

# --- Backend (requerido) ---
SECRET_KEY=change-me-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenRouter (requerido para pipeline IA) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- URL pública de la app (un solo dominio; nginx hace proxy de /api) ---
# Coolify: https://tu-dominio
FRONTEND_URL=https://tu-dominio.example

# Cookies httpOnly (prod HTTPS)
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Vacío con un solo dominio. Solo si usas subdominios: .astreo.space
COOKIE_DOMAIN=

# CORS: same-origin vía nginx. Opcional; si se setea, incluir el dominio público.
BACKEND_CORS_ORIGINS=https://tu-dominio.example

# --- Notion OAuth (opcional; necesario para «Añadir a Notion») ---
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Debe coincidir EXACTO con Redirect URI en https://www.notion.so/my-integrations
# Si se deja vacío, se usa {FRONTEND_URL}/api/v1/notion/oauth/callback
NOTION_OAUTH_REDIRECT_URI=https://tu-dominio.example/api/v1/notion/oauth/callback

# --- Storage PDFs ---
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_UPLOAD=15

# --- Storage compendios: S3 real en producción ---
STORAGE_BACKEND=s3
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=compendiums
S3_REGION=us-east-1
S3_USE_SSL=true
S3_PUBLIC_URL_PREFIX=

# --- App ---
DEBUG=false
UVICORN_RELOAD=

# =============================================================================
# Solo desarrollo local con MinIO:
#   docker compose --profile local up --build
# =============================================================================
# STORAGE_BACKEND=s3
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=compendiums
# S3_USE_SSL=false
# FRONTEND_URL=http://localhost:5173
# COOKIE_SECURE=false
# BACKEND_CORS_ORIGINS=http://localhost:5173
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
