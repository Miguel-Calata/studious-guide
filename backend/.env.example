# =============================================================================
# Backend — desarrollo local (sin Docker)
# Para Docker Compose / Coolify usa el .env.example de la raíz del repo.
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sam_platform

# JWT
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Notion OAuth (Public Integration)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/notion/oauth/callback

# Frontend (redirects OAuth)
FRONTEND_URL=http://localhost:5173

# Cookies (localhost: secure=false, domain vacío)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Storage (PDFs)
STORAGE_BACKEND=local
PDF_STORAGE_PATH=./data/pdfs
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_UPLOAD=15

# Storage (Compendios / S3-compatible) — MinIO local opcional
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=compendiums
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PUBLIC_URL_PREFIX=

# App
DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
